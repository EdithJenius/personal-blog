---
import { ArrowUpRight } from "@lucide/astro";

const { post } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<article class="post-card">
  <div class="post-meta">
    <span>{post.data.format} · {post.data.category}</span>
    <time datetime={post.data.publishedAt.toISOString()}>
      {post.data.publishedAt.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" })}
    </time>
  </div>
  <h3><a href={`${base}/posts/${post.id}/`}>{post.data.title}</a></h3>
  <p>{post.data.description}</p>
  <a class="read-link" href={`${base}/posts/${post.id}/`} aria-label={`阅读 ${post.data.title}`}>
    阅读文章 <ArrowUpRight size={16} />
  </a>
</article>

<style>
  .post-card {
    display: flex;
    min-height: 260px;
    padding: 26px 0 20px;
    border-top: 1px solid var(--line);
    flex-direction: column;
  }
  .post-meta { display: flex; align-items: center; justify-content: space-between; color: var(--muted); font-size: 12px; }
  .post-meta span { color: var(--green); font-weight: 750; }
  h3 { margin: 26px 0 12px; font-family: Georgia, "Noto Serif SC", serif; font-size: 25px; font-weight: 500; line-height: 1.35; }
  h3 a:hover { color: var(--accent); }
  p { margin: 0; color: var(--muted); font-size: 14px; line-height: 1.75; }
  .read-link { display: inline-flex; align-items: center; gap: 6px; margin-top: auto; padding-top: 20px; color: var(--accent); font-size: 13px; font-weight: 750; }
</style>
