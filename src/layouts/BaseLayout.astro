---
import { CodeXml, Menu, X } from "@lucide/astro";
import SystemGate from "../components/SystemGate.astro";

interface Props {
  title?: string;
  description?: string;
  showGate?: boolean;
}

const {
  title = "Edith | AI 产品与实践",
  description = "记录 AI 产品、Agent 系统与真实项目实践。",
  showGate = true
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, "");
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const nav = [
  { label: "首页", href: `${base}/` },
  { label: "文章", href: `${base}/posts/` },
  { label: "项目", href: `${base}/projects/` },
  { label: "关于", href: `${base}/about/` }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body>
    {showGate && <SystemGate />}
    <header class="site-header">
      <div class="shell header-inner">
        <a class="brand" href={`${base}/`} aria-label="Edith 首页">
          <span class="brand-mark">E</span>
          <span>Edith</span>
        </a>
        <button class="menu-button" type="button" aria-label="打开导航" aria-expanded="false">
          <Menu class="menu-open" size={21} />
          <X class="menu-close" size={21} />
        </button>
        <nav class="nav-links" aria-label="主导航">
          {nav.map((item) => (
            <a class:list={{ active: currentPath === item.href.replace(/\/$/, "") }} href={item.href}>
              {item.label}
            </a>
          ))}
          <a class="github-link" href="https://github.com/EdithJenius" target="_blank" rel="noreferrer" aria-label="GitHub">
            <CodeXml size={19} />
          </a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell footer-inner">
        <p>在真实问题里学习，在持续交付中成长。</p>
        <div class="footer-links" aria-label="法律与政策链接">
          <a href={`${base}/terms/`}>Terms</a>
          <a href={`${base}/privacy/`}>Privacy</a>
          <span>© {new Date().getFullYear()} Edith</span>
        </div>
      </div>
    </footer>
    <script>
      const button = document.querySelector(".menu-button");
      const nav = document.querySelector(".nav-links");
      button?.addEventListener("click", () => {
        const open = button.getAttribute("aria-expanded") === "true";
        button.setAttribute("aria-expanded", String(!open));
        nav?.classList.toggle("open");
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --ink: #171a1f;
    --muted: #626a73;
    --line: #d9dde2;
    --paper: #f7f7f4;
    --surface: #ffffff;
    --accent: #b8402a;
    --accent-soft: #f1ded7;
    --green: #315c4b;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--ink);
    background: var(--paper);
    font-synthesis: none;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; min-width: 320px; background: var(--paper); }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }
  button { font: inherit; }
  .shell { width: min(1120px, calc(100% - 40px)); margin: 0 auto; }
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid rgba(217, 221, 226, .86);
    background: rgba(247, 247, 244, .94);
    backdrop-filter: blur(12px);
  }
  .header-inner { min-height: 68px; display: flex; align-items: center; justify-content: space-between; }
  .brand { display: inline-flex; align-items: center; gap: 10px; font-size: 18px; font-weight: 720; }
  .brand-mark {
    display: grid;
    width: 30px;
    height: 30px;
    place-items: center;
    color: white;
    background: var(--accent);
    font-family: Georgia, serif;
    font-size: 19px;
  }
  .nav-links { display: flex; align-items: center; gap: 28px; color: #4d545c; font-size: 14px; }
  .nav-links a { padding: 8px 0; }
  .nav-links a:hover, .nav-links a.active { color: var(--ink); }
  .nav-links a.active { box-shadow: inset 0 -2px var(--accent); }
  .github-link { display: inline-grid; place-items: center; }
  .menu-button { display: none; border: 0; background: transparent; color: var(--ink); padding: 7px; }
  .menu-close { display: none; }
  .site-footer { border-top: 1px solid var(--line); margin-top: 88px; }
  .footer-inner { min-height: 100px; display: flex; align-items: center; justify-content: space-between; color: var(--muted); font-size: 13px; }
  .footer-links { display: flex; align-items: center; gap: 18px; }
  .footer-links a:hover { color: var(--accent); }
  .eyebrow { margin: 0 0 16px; color: var(--accent); font-size: 12px; font-weight: 750; letter-spacing: 0; text-transform: uppercase; }
  .section-title { margin: 0; font-family: Georgia, "Noto Serif SC", serif; font-size: clamp(30px, 4vw, 46px); font-weight: 500; line-height: 1.15; }
  .section-lead { max-width: 640px; color: var(--muted); font-size: 16px; line-height: 1.8; }
  .text-link { display: inline-flex; align-items: center; gap: 7px; color: var(--accent); font-weight: 700; font-size: 14px; }
  @media (max-width: 720px) {
    .shell { width: min(100% - 28px, 1120px); }
    .menu-button { display: inline-grid; place-items: center; }
    .menu-button[aria-expanded="true"] .menu-open { display: none; }
    .menu-button[aria-expanded="true"] .menu-close { display: block; }
    .nav-links {
      display: none;
      position: absolute;
      inset: 68px 0 auto;
      padding: 18px 20px 24px;
      align-items: stretch;
      gap: 2px;
      border-bottom: 1px solid var(--line);
      background: var(--paper);
      flex-direction: column;
    }
    .nav-links.open { display: flex; }
    .nav-links a { padding: 12px 4px; }
    .nav-links a.active { box-shadow: none; color: var(--accent); }
    .github-link { justify-content: start; }
    .footer-inner { align-items: flex-start; flex-direction: column; justify-content: center; gap: 10px; }
    .footer-inner p { margin: 0; }
    .footer-links { flex-wrap: wrap; gap: 12px 18px; }
  }
</style>
