---
import { getCollection } from "astro:content";
import { ArrowRight, BrainCircuit, CodeXml, Layers3, Sparkles } from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const featured = posts.filter((post) => post.data.featured).slice(0, 3);
const knowledgeEngineUrl = `${base}/knowledge-engine/index.html`;
---

<BaseLayout>
  <section class="hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">AI PRODUCT · AGENT · PRACTICE</p>
        <h1>在复杂问题里，<br />做清晰、有用的产品。</h1>
        <p class="hero-intro">
          我是 Edith，关注 AI 产品、Agent 系统与知识工作流。
          这里记录我的项目实践、方法思考，以及那些真正落地之后才会遇到的问题。
        </p>
        <div class="hero-actions">
          <a class="primary-action" href={`${base}/posts/`}>阅读文章 <ArrowRight size={17} /></a>
          <a class="secondary-action" href={`${base}/projects/`}>查看项目</a>
        </div>
        <div class="proof-row" aria-label="内容概览">
          <span><strong>3</strong> 个实践方向</span>
          <span><strong>4</strong> 个公开项目</span>
          <span><strong>持续</strong> 更新笔记</span>
        </div>
      </div>
      <div class="hero-visual" aria-label="工作主题">
        <div class="visual-heading">
          <span>FIELD NOTES</span>
          <span>2026</span>
        </div>
        <div class="visual-center">
          <Sparkles size={28} stroke-width={1.5} />
          <strong>Ideas<br />into<br />systems.</strong>
        </div>
        <div class="visual-footer">
          <span>产品判断</span><span>系统设计</span><span>持续交付</span>
        </div>
      </div>
    </div>
  </section>

  <section class="topic-strip">
    <div class="shell topic-inner">
      <p>知识主题</p>
      <div>
        <a href={`${base}/posts/`}>AI 产品</a>
        <a href={`${base}/posts/`}>Agent 系统</a>
        <a href={`${base}/posts/`}>知识工作流</a>
        <a href={`${base}/projects/`}>项目复盘</a>
      </div>
    </div>
  </section>

  <section class="focus">
    <div class="shell">
      <div class="focus-heading">
        <div>
          <p class="eyebrow">CURRENT FOCUS</p>
          <h2 class="section-title">正在研究与实践</h2>
        </div>
        <p class="section-lead">我更关心 AI 如何进入真实工作，而不只是展示能力。以下是目前持续投入的三个方向。</p>
      </div>
      <div class="focus-grid">
        <article>
          <span class="focus-number">01</span>
          <h3>AI 产品化</h3>
          <p>从业务问题、用户流程到评估指标，把模型能力转化为可反复使用的产品。</p>
        </article>
        <article>
          <span class="focus-number">02</span>
          <h3>Agent 系统</h3>
          <p>探索多 Agent 协作、上下文管理、工具调用，以及长期任务中的可靠交付。</p>
        </article>
        <article>
          <span class="focus-number">03</span>
          <h3>知识工作流</h3>
          <p>让知识库不再只是资料集合，而是能支持判断、执行、复盘与持续迭代的系统。</p>
        </article>
      </div>
    </div>
  </section>

  <section class="engine-panel" id="knowledge-engine">
    <div class="shell engine-grid">
      <div>
        <p class="eyebrow">KNOWLEDGE ENGINE</p>
        <h2 class="section-title">知识迭代引擎网页端</h2>
        <p class="section-lead">
          一个用于查看学习主线、实验进度、评测结果、Codex 反馈和能力进展的操作台。
          后台知识收集与写入交给 Codex，网页端负责把当前状态清楚地呈现出来。
        </p>
        <a class="engine-link" href={knowledgeEngineUrl}>
          打开网页端 <ArrowRight size={17} />
        </a>
      </div>
      <a class="engine-preview" href={knowledgeEngineUrl} aria-label="打开知识迭代引擎网页端">
        <div class="engine-preview-head">
          <span><BrainCircuit size={18} /> Learning View</span>
          <strong>LIVE</strong>
        </div>
        <div class="engine-preview-body">
          <div>
            <span>实验进度</span>
            <strong>72%</strong>
          </div>
          <div>
            <span>评测通过</span>
            <strong>8/10</strong>
          </div>
          <div>
            <span>反馈记录</span>
            <strong>24</strong>
          </div>
        </div>
      </a>
    </div>
  </section>

  <section class="lab-updates" id="mini-program-data-merge">
    <div class="shell">
      <div class="section-row">
        <div>
          <p class="eyebrow">UPDATE LOG</p>
          <h2 class="section-title">小程序开发与数据合并实验</h2>
        </div>
        <a class="text-link" href="https://github.com/EdithJenius/Codex_f" target="_blank" rel="noreferrer">
          查看代码 <ArrowRight size={16} />
        </a>
      </div>
      <div class="update-grid">
        <article>
          <span class="update-index">01</span>
          <h3>微信小程序业务前端</h3>
          <p>
            基于 vt-weixin01 梳理酒店、优惠券、权益、用户与门店接口，沉淀小程序端请求封装、
            状态管理、Vant Weapp 组件集成和地图能力接入。
          </p>
        </article>
        <article>
          <span class="update-index">02</span>
          <h3>酒店房型动态适配</h3>
          <p>
            围绕游虾鲸酒店数据接入，设计酒店映射表、房型价格动态查询、早餐与取消规则适配，
            尽量保持现有小程序接口稳定。
          </p>
        </article>
        <article>
          <span class="update-index">03</span>
          <h3>多源数据合并</h3>
          <p>
            将供应商侧 whaleHotelId、whaleRoomId、ratePlanId、detailId 等关键标识保留下来，
            为后续多供应商房型合并、标准化展示和可下单链路预留空间。
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="latest">
    <div class="shell">
      <div class="section-row">
        <div>
          <p class="eyebrow">LATEST WRITING</p>
          <h2 class="section-title">近期文章</h2>
        </div>
        <a class="text-link" href={`${base}/posts/`}>查看全部 <ArrowRight size={16} /></a>
      </div>
      <div class="post-grid">
        {featured.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>

  <section class="project-band">
    <div class="shell project-inner">
      <div class="project-icon"><Layers3 size={26} /></div>
      <div>
        <p class="eyebrow">SELECTED WORK</p>
        <h2>把探索做成可以使用的东西。</h2>
        <p>从 ERP 工具、课程体系到内容与知识工作流，我在项目里验证想法，也在交付里修正判断。</p>
      </div>
      <a href={`${base}/projects/`}>项目档案 <ArrowRight size={17} /></a>
    </div>
  </section>

  <section class="connect">
    <div class="shell connect-inner">
      <div>
        <p class="eyebrow">CONNECT</p>
        <h2 class="section-title">保持交流，也保持好奇。</h2>
      </div>
      <a href="https://github.com/EdithJenius" target="_blank" rel="noreferrer">
        <CodeXml size={20} /> GitHub
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding: 76px 0 68px; border-bottom: 1px solid var(--line); }
  .hero-grid { display: grid; grid-template-columns: minmax(0, 1.35fr) minmax(320px, .65fr); gap: 80px; align-items: stretch; }
  .hero-copy { padding: 32px 0 28px; }
  h1 { max-width: 760px; margin: 0; font-family: Georgia, "Noto Serif SC", serif; font-size: clamp(48px, 7vw, 82px); font-weight: 500; line-height: 1.08; }
  .hero-intro { max-width: 650px; margin: 32px 0 0; color: var(--muted); font-size: 17px; line-height: 1.9; }
  .hero-actions { display: flex; align-items: center; gap: 22px; margin-top: 38px; }
  .primary-action, .secondary-action { display: inline-flex; align-items: center; justify-content: center; min-height: 44px; font-size: 14px; font-weight: 750; }
  .primary-action { gap: 8px; padding: 0 20px; color: white; background: var(--ink); }
  .primary-action:hover { background: var(--accent); }
  .secondary-action { border-bottom: 1px solid var(--ink); }
  .proof-row { display: flex; flex-wrap: wrap; gap: 22px; margin-top: 46px; color: var(--muted); font-size: 12px; }
  .proof-row span { display: inline-flex; align-items: baseline; gap: 5px; }
  .proof-row strong { color: var(--ink); font-family: Georgia, serif; font-size: 16px; font-weight: 500; }
  .hero-visual { display: flex; min-height: 430px; padding: 24px; color: #f6f2e9; background: var(--green); flex-direction: column; justify-content: space-between; }
  .visual-heading, .visual-footer { display: flex; align-items: center; justify-content: space-between; font-size: 11px; font-weight: 700; }
  .visual-center { display: flex; align-items: flex-start; gap: 20px; }
  .visual-center strong { font-family: Georgia, serif; font-size: 50px; font-weight: 500; line-height: .92; }
  .visual-footer { border-top: 1px solid rgba(255,255,255,.28); padding-top: 17px; }
  .topic-strip { border-bottom: 1px solid var(--line); background: var(--surface); }
  .topic-inner { display: flex; min-height: 76px; align-items: center; justify-content: space-between; }
  .topic-inner p { margin: 0; color: var(--muted); font-size: 12px; font-weight: 750; }
  .topic-inner div { display: flex; flex-wrap: wrap; gap: 30px; }
  .topic-inner a { font-family: Georgia, "Noto Serif SC", serif; font-size: 15px; }
  .topic-inner a:hover { color: var(--accent); }
  .focus, .latest, .lab-updates { padding: 88px 0; }
  .focus { background: var(--surface); }
  .focus-heading { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: end; }
  .focus-heading .section-lead { margin: 0; }
  .focus-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 36px; margin-top: 64px; }
  .focus-grid article { padding-top: 22px; border-top: 1px solid var(--ink); }
  .focus-number { color: var(--accent); font-family: Georgia, serif; font-size: 13px; }
  .focus-grid h3 { margin: 40px 0 14px; font-family: Georgia, "Noto Serif SC", serif; font-size: 25px; font-weight: 500; }
  .focus-grid p { margin: 0; color: var(--muted); font-size: 14px; line-height: 1.8; }
  .engine-panel { padding: 82px 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: #eef4f2; }
  .engine-grid { display: grid; grid-template-columns: minmax(0, .95fr) minmax(340px, 1.05fr); gap: 64px; align-items: center; }
  .engine-link { display: inline-flex; align-items: center; gap: 8px; min-height: 44px; margin-top: 28px; padding: 0 18px; color: white; background: var(--green); font-size: 14px; font-weight: 750; }
  .engine-link:hover { background: var(--accent); }
  .engine-preview { display: block; padding: 18px; color: #e9fcfb; background: #101820; border: 1px solid #2c4449; }
  .engine-preview-head { display: flex; align-items: center; justify-content: space-between; padding-bottom: 18px; border-bottom: 1px solid rgba(233,252,251,.18); font-size: 12px; font-weight: 750; }
  .engine-preview-head span { display: inline-flex; align-items: center; gap: 8px; }
  .engine-preview-head strong { color: #75ebc0; font-size: 11px; }
  .engine-preview-body { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 18px; }
  .engine-preview-body div { min-height: 134px; padding: 16px; background: rgba(255,255,255,.06); border: 1px solid rgba(233,252,251,.12); }
  .engine-preview-body span { display: block; color: #9fb8bd; font-size: 12px; }
  .engine-preview-body strong { display: block; margin-top: 42px; font-family: Georgia, serif; font-size: 31px; font-weight: 500; }
  .lab-updates { background: var(--surface); border-bottom: 1px solid var(--line); }
  .update-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-top: 46px; }
  .update-grid article { min-height: 256px; padding: 22px; background: #fffdf8; border: 1px solid var(--line); }
  .update-index { color: var(--accent); font-family: Georgia, serif; font-size: 13px; }
  .update-grid h3 { margin: 34px 0 14px; font-family: Georgia, "Noto Serif SC", serif; font-size: 24px; font-weight: 500; }
  .update-grid p { margin: 0; color: var(--muted); font-size: 14px; line-height: 1.85; }
  .section-row { display: flex; align-items: end; justify-content: space-between; }
  .post-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 42px; margin-top: 48px; }
  .project-band { padding: 72px 0; color: #f5f1e7; background: var(--ink); }
  .project-inner { display: grid; grid-template-columns: auto 1fr auto; gap: 30px; align-items: center; }
  .project-icon { display: grid; width: 54px; height: 54px; place-items: center; border: 1px solid #4c5259; }
  .project-band .eyebrow { margin-bottom: 10px; color: #e78068; }
  .project-band h2 { margin: 0; font-family: Georgia, "Noto Serif SC", serif; font-size: 34px; font-weight: 500; }
  .project-band p:not(.eyebrow) { max-width: 680px; margin: 12px 0 0; color: #b8bdc3; line-height: 1.75; }
  .project-band a { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 750; }
  .connect { padding: 88px 0 0; }
  .connect-inner { display: flex; align-items: end; justify-content: space-between; }
  .connect a { display: inline-flex; align-items: center; gap: 9px; padding: 12px 0; border-bottom: 1px solid var(--ink); font-weight: 700; }
  @media (max-width: 820px) {
    .hero { padding-top: 38px; }
    .hero-grid { grid-template-columns: 1fr; gap: 34px; }
    .hero-visual { min-height: 320px; }
    .focus-heading { grid-template-columns: 1fr; gap: 24px; }
    .focus-grid { grid-template-columns: 1fr; gap: 32px; }
    .focus-grid h3 { margin-top: 24px; }
    .engine-grid { grid-template-columns: 1fr; gap: 34px; }
    .update-grid { grid-template-columns: 1fr; }
    .update-grid article { min-height: auto; }
    .post-grid { grid-template-columns: 1fr; }
    .project-inner { grid-template-columns: auto 1fr; }
    .project-inner > a { grid-column: 2; justify-self: start; }
  }
  @media (max-width: 560px) {
    h1 { font-size: 46px; }
    .hero-intro { font-size: 16px; }
    .hero-actions { align-items: flex-start; flex-direction: column; }
    .proof-row { gap: 12px 18px; }
    .topic-inner { padding: 18px 0; align-items: flex-start; flex-direction: column; gap: 14px; }
    .topic-inner div { gap: 12px 22px; }
    .visual-center strong { font-size: 42px; }
    .engine-preview-body { grid-template-columns: 1fr; }
    .engine-preview-body div { min-height: 96px; }
    .engine-preview-body strong { margin-top: 22px; }
    .section-row, .connect-inner { align-items: flex-start; flex-direction: column; gap: 24px; }
    .project-inner { grid-template-columns: 1fr; }
    .project-inner > a { grid-column: 1; }
  }
</style>
