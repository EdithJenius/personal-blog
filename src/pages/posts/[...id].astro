---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Edith`} description={post.data.description}>
  <article>
    <header class="article-head">
      <div class="article-shell">
        <div class="article-meta">
          <span>{post.data.category}</span>
          <time datetime={post.data.publishedAt.toISOString()}>
            {post.data.publishedAt.toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" })}
          </time>
        </div>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
      </div>
    </header>
    <div class="article-shell prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .article-shell { width: min(760px, calc(100% - 40px)); margin: 0 auto; }
  .article-head { padding: 84px 0 62px; border-bottom: 1px solid var(--line); }
  .article-meta { display: flex; align-items: center; gap: 20px; color: var(--muted); font-size: 13px; }
  .article-meta span { color: var(--accent); font-weight: 750; }
  .article-head h1 { margin: 24px 0 20px; font-family: Georgia, "Noto Serif SC", serif; font-size: clamp(44px, 7vw, 68px); font-weight: 500; line-height: 1.15; }
  .article-head p { max-width: 650px; margin: 0; color: var(--muted); font-size: 18px; line-height: 1.8; }
  .prose { padding: 58px 0 20px; font-family: Georgia, "Noto Serif SC", serif; font-size: 18px; line-height: 2; }
  .prose h2 { margin: 54px 0 16px; font-size: 30px; font-weight: 500; line-height: 1.35; }
  .prose p { margin: 0 0 24px; }
  .prose ol, .prose ul { padding-left: 24px; }
  .prose li { margin: 9px 0; }
  @media (max-width: 600px) {
    .article-shell { width: min(100% - 28px, 760px); }
    .article-head { padding-top: 54px; }
    .prose { font-size: 17px; }
  }
</style>
